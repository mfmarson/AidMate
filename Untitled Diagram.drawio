  <diagram id="PuVkffSAe6ptdI-lqt37" name="Page-7">
    <mxGraphModel dx="824" dy="1886" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="nSbJExJbKzpzdGmyBKO5-1" value="&lt;br&gt;&lt;br&gt;&lt;br&gt;Key Features&lt;br&gt;&lt;ul&gt;&lt;li&gt;First Aid Instructions&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Access clear and concise first aid instructions for a variety of emergencies.&lt;/li&gt;&lt;li&gt;Step-by-step guides with images and videos to help you provide immediate assistance.&lt;/li&gt;&lt;li&gt;GPS Emergency Location Mapping&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Share your exact location with emergency responders at the touch of a button.&lt;/li&gt;&lt;li&gt;Ensure that help arrives quickly when you need it most.&lt;/li&gt;&lt;li&gt;Offline Access&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Download first aid instructions for use in remote areas with no internet connectivity.&lt;/li&gt;&lt;li&gt;Be prepared to assist in any situation, regardless of connectivity.&lt;/li&gt;&lt;li&gt;Multilingual Support&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Access first aid instructions in multiple languages.&lt;/li&gt;&lt;li&gt;Ensure that you and others can understand and follow the instructions accurately.&lt;/li&gt;&lt;li&gt;Emergency Contacts Notification&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Notify your pre-set emergency contacts with your location and situation.&lt;/li&gt;&lt;li&gt;Ensure your loved ones are informed and can assist or alert authorities.&lt;/li&gt;&lt;li&gt;User Profile and Medical Information&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Store and manage your personal and medical information securely.&lt;/li&gt;&lt;li&gt;Provide emergency responders with quick access to your critical health data.&lt;/li&gt;&lt;li&gt;Interactive First Aid Scenarios&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Engage in interactive scenarios and quizzes to enhance your first aid knowledge.&lt;/li&gt;&lt;li&gt;Retain crucial information and be better prepared for real-life situations.&lt;/li&gt;&lt;li&gt;Why Choose AidMate?&lt;/li&gt;&lt;li&gt;User-Friendly Interface&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Designed for ease of use, ensuring you can find the information you need quickly.&lt;/li&gt;&lt;li&gt;Intuitive navigation and clear instructions make it accessible to everyone.&lt;/li&gt;&lt;li&gt;Reliable and Up-to-Date Information&lt;/li&gt;&lt;li&gt;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Regular updates to ensure the latest medical guidelines are available.&lt;/li&gt;&lt;li&gt;Content reviewed and approved by medical professionals.&lt;/li&gt;&lt;li&gt;Comprehensive Support&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;24/7 access to first aid information and emergency services.&lt;br&gt;Support for a wide range of medical emergencies, from minor injuries to critical situations.&lt;br&gt;Stay Safe, Stay Prepared&lt;br&gt;With AidMate, you can have peace of mind knowing that you have a reliable first aid companion at your fingertips. Equip yourself with the knowledge and tools to handle emergencies confidently and effectively. Download AidMate today and be prepared to make a difference when it matters most." style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="-20" width="560" height="830" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
