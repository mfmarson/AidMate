        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-12" value="Want To" style="shape=tableRow;horizontal=0;swimlaneHead=0;swimlaneBody=0;top=0;left=0;strokeColor=inherit;bottom=0;right=0;dropTarget=0;fontStyle=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;startSize=40;collapsible=0;recursiveResize=0;expand=0;fontSize=16;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-3">
          <mxGeometry y="160" width="790" height="160" as="geometry" />
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-14" value="" style="swimlane;swimlaneHead=0;swimlaneBody=0;fontStyle=0;connectable=0;strokeColor=inherit;fillColor=none;startSize=0;collapsible=0;recursiveResize=0;expand=0;fontSize=16;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-12">
          <mxGeometry x="40" width="750" height="160" as="geometry">
            <mxRectangle width="750" height="160" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-19" value="Provide clear, concise, and step-by-step instructions for a wide range of emergency situations.&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br style=&quot;font-size: 14px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Types of Emergency Instructions:&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Directions to the Emergency Room&amp;nbsp;&amp;nbsp;&lt;br style=&quot;font-size: 14px;&quot;&gt;Choking -&amp;gt; Heimlich&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Unresponsive -&amp;gt; CPR&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Burn -&amp;gt; Cool and Cover&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Bleeding -&amp;gt; Clean, Tunicate, Emergency Room&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;ETC.&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br style=&quot;font-size: 14px;&quot;&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-14">
          <mxGeometry x="30" y="44" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-16" value="So That" style="shape=tableRow;horizontal=0;swimlaneHead=0;swimlaneBody=0;top=0;left=0;strokeColor=inherit;bottom=0;right=0;dropTarget=0;fontStyle=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;startSize=40;collapsible=0;recursiveResize=0;expand=0;fontSize=16;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-3">
          <mxGeometry y="320" width="790" height="133" as="geometry" />
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-17" style="swimlane;swimlaneHead=0;swimlaneBody=0;fontStyle=0;connectable=0;strokeColor=inherit;fillColor=none;startSize=0;collapsible=0;recursiveResize=0;expand=0;fontSize=16;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-16">
          <mxGeometry x="40" width="750" height="133" as="geometry">
            <mxRectangle width="750" height="133" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-20" value="Users can act quickly and effectively to bridge the gap between witnessing an emergency and professional medical help arriving, enabling users to make a positive impact during critical moments.&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br style=&quot;font-size: 14px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Possible Outcomes:&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Medical professional arrives - afflicted person is stable and ready for professional aid&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Emergency is resolved (Not choking, responsive)&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br style=&quot;font-size: 14px;&quot;&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="y8HZ5NCk93fEaW_qW8cW-17">
          <mxGeometry x="30" y="30" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="y8HZ5NCk93fEaW_qW8cW-18" value="Anyone who can use a mobile phone or website and is capable of providing hands-on assistance.&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br style=&quot;font-size: 14px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Ages: Young Adults, Teens, Adults, Older Children, Elderly&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Occupation: Any&lt;/div&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;Technology Proficiency: Basic+&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="270" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="6FSMNmG6Xc1Va60B7Q4_-5" value="&lt;h1 style=&quot;forced-color-adjust: none; margin-top: 0px; font-size: 16px;&quot;&gt;&lt;u style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Sara&lt;/u&gt;&lt;/h1&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Sarah, a busy parent who often cooks meals for her family, is preparing dinner in the kitchen when her young child accidentally touches a hot pan and gets a burn.&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-In need of immediate first aid guidance, Sarah quickly opens the first aid app on her phone.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-She selects the &quot;Burns&quot; category from the main menu, which provides her with a clear, step-by-step guide complete with&lt;span style=&quot;forced-color-adjust: none; white-space: pre; font-size: 16px;&quot;&gt;&lt;span style=&quot;white-space: pre; font-size: 16px;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/span&gt;visuals and text.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-Following the app’s instructions, Sarah cools the burn under running water, covers it with a sterile bandage, and manages her child’s pain.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Thanks to the app, Sarah successfully administers first aid, feeling confident and reassured by its guidance. Her child’s pain is alleviated, and the burn is properly treated, reducing the risk of complications. The app’s ease of navigation and quick access to information proves invaluable in this stressful moment.&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontSize=16;align=center;" vertex="1" parent="1">
          <mxGeometry x="23" y="690" width="805" height="340" as="geometry" />
        </mxCell>
        <mxCell id="6FSMNmG6Xc1Va60B7Q4_-6" value="&lt;h1 style=&quot;margin-top: 0px; font-size: 16px;&quot;&gt;&lt;u style=&quot;font-size: 16px;&quot;&gt;Alex&lt;/u&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; font-size: 16px;&quot;&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-weight: normal; font-size: 16px;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Alex, a young adult and active member of his community, is attending a local event at the community center when he notices someone nearby suddenly collapse and appear unresponsive.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;br style=&quot;font-size: 16px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: initial; font-size: 16px;&quot;&gt;-Realizing that immediate action is needed, Alex quickly opens the first aid app on his phone.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;-He navigates to the &quot;Unresponsive Person&quot; section, where he finds clear, step-by-step instructions on how to perform CPR.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;-The app provides detailed guidance with visuals, showing him how to check for responsiveness and breathing, call emergency services, and begin chest compressions and rescue breaths.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;-Following the app’s instructions, Alex performs CPR confidently until professional help arrives.&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;&lt;br style=&quot;font-size: 16px;&quot;&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;font-weight: normal; font-size: 16px;&quot;&gt;The app’s easy-to-follow guidance helps Alex provide critical assistance, potentially saving the person&#39;s life, and highlights the importance of having accessible first aid information in community settings.&lt;/font&gt;&lt;/div&gt;&lt;/h1&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="23" y="1060" width="805" height="400" as="geometry" />
        </mxCell>
        <mxCell id="6FSMNmG6Xc1Va60B7Q4_-10" value="&lt;h1 style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; margin-top: 0px; font-size: 16px;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; background-color: initial; font-size: 16px;&quot;&gt;&lt;u style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Taylor&lt;/u&gt;&lt;/span&gt;&lt;/h1&gt;&lt;div style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 16px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;font style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Taylor, a college student, is hiking with friends when one of them slips and cuts their leg on a sharp rock, causing significant bleeding.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-Acting quickly, Taylor opens the first aid app on his phone and selects the &quot;Bleeding&quot; category.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-The app provides clear, step-by-step instructions with visuals, guiding Taylor to apply direct pressure to the wound using a clean cloth to control the bleeding.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-After a few minutes, the bleeding is still profuse, and the app advises that professional medical help is necessary.&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none; font-size: 16px; background-color: initial;&quot;&gt;-Using the app&#39;s integrated GPS feature, Taylor searches for the nearest hospital or urgent care facility.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-The app provides directions and real-time navigation, ensuring they can reach the closest medical center promptly.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;-On the way, the app continues to provide additional tips, such as keeping the injured limb elevated and ensuring the cloth stays in place.&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;&lt;br style=&quot;forced-color-adjust: none; font-size: 16px;&quot;&gt;Thanks to the first aid app, Taylor is able to manage the bleeding effectively and navigate to the nearest hospital, ensuring his friend receives the necessary medical attention quickly and safely.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="23" y="1500" width="807" height="410" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
