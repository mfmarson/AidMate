    <mxGraphModel dx="1638" dy="663" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="xBxcX-ZuxiAc--fYgXEH-1" value="&lt;li&gt;&lt;p&gt;&lt;strong&gt;Cuts and Scrapes&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Clean the wound with water.&lt;/li&gt;&lt;li&gt;Apply an antiseptic.&lt;/li&gt;&lt;li&gt;Cover with a sterile bandage.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Burns&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Cool the burn with running water for at least 10 minutes.&lt;/li&gt;&lt;li&gt;Cover with a sterile, non-stick bandage.&lt;/li&gt;&lt;li&gt;Avoid applying creams or ointments.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Sprains and Strains&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Rest the injured area.&lt;/li&gt;&lt;li&gt;Apply ice to reduce swelling.&lt;/li&gt;&lt;li&gt;Compress with an elastic bandage.&lt;/li&gt;&lt;li&gt;Elevate the injured limb.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Choking&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Perform the Heimlich maneuver.&lt;/li&gt;&lt;li&gt;Encourage coughing if the person is able to.&lt;/li&gt;&lt;li&gt;Call emergency services if the blockage is not cleared.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Nosebleeds&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Sit upright and lean forward.&lt;/li&gt;&lt;li&gt;Pinch the soft part of the nose.&lt;/li&gt;&lt;li&gt;Hold for 10-15 minutes and avoid blowing the nose.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Fractures&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Immobilize the affected area.&lt;/li&gt;&lt;li&gt;Apply a splint if trained.&lt;/li&gt;&lt;li&gt;Seek professional medical help immediately.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Heart Attack&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Call emergency services immediately.&lt;/li&gt;&lt;li&gt;Have the person sit down and stay calm.&lt;/li&gt;&lt;li&gt;If available, administer aspirin (unless allergic).&lt;/li&gt;&lt;li&gt;Monitor and provide CPR if necessary.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Stroke&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Call emergency services immediately.&lt;/li&gt;&lt;li&gt;Note the time of symptom onset.&lt;/li&gt;&lt;li&gt;Keep the person comfortable and calm.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;Allergic Reactions&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Administer an epinephrine auto-injector if available.&lt;/li&gt;&lt;li&gt;Call emergency services.&lt;/li&gt;&lt;li&gt;Monitor the person for signs of anaphylaxis.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;strong&gt;CPR (Cardiopulmonary Resuscitation)&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Check for responsiveness and breathing.&lt;/li&gt;&lt;li&gt;Call emergency services.&lt;/li&gt;&lt;li&gt;Begin chest compressions and rescue breaths.&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="370" height="1130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
